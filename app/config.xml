<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="http://yourname.com/IPTVApp"
        version="1.0.0"
        viewmodes="maximized">

  <tizen:application id="IPTV12345.IPTVApp"
                     package="IPTV12345"
                     required_version="6.0"/>

  <content src="index.html"/>
  <icon src="icon.png"/>
  <name>IPTV Pro</name>
  <description>Telugu, India &amp; JioTV channels</description>

  <!-- Required privileges -->
  <tizen:privilege name="http://tizen.org/privilege/internet"/>
  <tizen:privilege name="http://tizen.org/privilege/display"/>
  <tizen:privilege name="http://tizen.org/privilege/tv.inputdevice"/>

  <!-- Allow all network access including Jio APIs -->
  <access origin="*" subdomains="true"/>

  <!-- Android TV spoof metadata — reported to external services -->
  <tizen:metadata key="http://samsung.com/tv/metadata/prelaunch.support"     value="true"/>
  <tizen:metadata key="http://samsung.com/tv/metadata/resume_app_on_standby" value="true"/>

  <!-- CSP: allow Jio CDN, Akamai, and proxy -->
  <tizen:content-security-policy>
    default-src * 'unsafe-inline' 'unsafe-eval' data: blob:;
    media-src * blob: data:;
    connect-src *;
  </tizen:content-security-policy>

  <!-- App settings -->
  <tizen:setting screen-orientation="landscape"
                 context-menu="disable"
                 background-support="enable"
                 encryption="disable"
                 install-location="auto"
                 hw-key-event="true"/>

  <feature name="http://tizen.org/feature/screen.size.all"/>

</widget>
