{
  "name": "iptv",
  "version": "2.0.0",
  "description": "Premium IPTV player for TizenBrew — Samsung TV",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "app",
    "service.js",
    "README.md",
    "package.json"
  ],
  "keywords": [
    "tizen",
    "tizenbrew",
    "iptv",
    "m3u",
    "hls",
    "samsung",
    "tv"
  ],
  "packageType": "app",
  "appName": "IPTV",
  "appPath": "app/index.html",
  "serviceFile": "service.js",
  "evaluateScriptOnDocumentStart": false,
  "keys": [
    "MediaPlay",
    "MediaPause",
    "MediaPlayPause",
    "MediaStop",
    "MediaFastForward",
    "MediaRewind",
    "ColorF0Red",
    "ColorF1Green",
    "ColorF2Yellow",
    "ColorF3Blue",
    "ChannelUp",
    "ChannelDown",
    "Back"
  ]
}
